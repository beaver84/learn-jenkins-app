{
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "family": "learn-jenkins-app-prod",
    "containerDefinitions": [
        {
            "name": "learnjenkinsapp",
            "image": "047593685049.dkr.ecr.ap-northeast-2.amazonaws.com/myjenkinsapp:1.0.77",
            "portMappings": [{
                "name": "nginx-80-tip",
                "containerPort": 80,
                "hostPort": 80,
                "protocol": "tcp",
                "appProtocol": "http"
            }],
            
            "essential": true
        }
    ],
    "volumes": [],
    "networkMode": "awsvpc",
    "memory": "512",
    "cpu": "256",
    "executionRoleArn": "arn:aws:iam::047593685049:role/ecsTaskExecutionRole"
}